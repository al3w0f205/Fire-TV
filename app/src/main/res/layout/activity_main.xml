<?xml version="1.0" encoding="utf-8"?>
<!--
    Main TV layout — "Liquid Glass" UI/UX
    
    Layer stack (bottom to top):
    1. Full-bleed blurred album art background
    2. Animated gradient overlay (very subtle fluid color tint)
    3. Bottom vignette gradient
    4. Content: centered album art + compact glass control panel
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    tools:context=".MainActivity">

    <!-- Layer 1: Immersive edge-to-edge blurred album art background -->
    <ImageView
        android:id="@+id/ivBackgroundBlur"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_album_placeholder"
        android:contentDescription="@null" />

    <!-- Layer 2: Animated gradient overlay (very subtle tint) -->
    <com.fireairplay.receiver.ui.AnimatedGradientView
        android:id="@+id/animatedGradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Layer 3: Top vignette for depth -->
    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="top"
        android:background="@drawable/top_gradient_overlay" />

    <!-- Layer 3b: Bottom vignette for panel contrast -->
    <View
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_gradient_overlay" />

    <!-- Layer 4: Main content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="40dp">

        <!-- Connection status indicator (top-left) -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/status_waiting"
            android:textColor="#99FFFFFF"
            android:textSize="15sp"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- AirPlay branding & settings button (top-right, D-pad focusable) -->
        <LinearLayout
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:focusable="true"
            android:clickable="true"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:background="@drawable/settings_button_background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:contentDescription="Ajustes"
                android:tint="#99FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="sans-serif-light"
                android:text="Ajustes"
                android:textColor="#99FFFFFF"
                android:textSize="14sp"
                android:letterSpacing="0.05"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3" />
        </LinearLayout>

        <!-- Guideline separating left side from right side -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_split"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.45" />

        <!-- Floating shadow beneath album art -->
        <View
            android:id="@+id/albumShadow"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:background="@drawable/album_shadow"
            android:alpha="0.6"
            app:layout_constraintBottom_toBottomOf="@id/cardAlbumArt"
            app:layout_constraintEnd_toEndOf="@id/cardAlbumArt"
            app:layout_constraintStart_toStartOf="@id/cardAlbumArt"
            android:translationY="20dp" />

        <!-- Album art — Large, left-aligned, with soft rounded corners -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAlbumArt"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="24dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toStartOf="@id/guideline_split"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="420dp">

            <ImageView
                android:id="@+id/ivAlbumArt"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_album_placeholder"
                android:contentDescription="Album artwork" />

        </androidx.cardview.widget.CardView>

        <!-- Right Side Panel containing Track Info and Progress -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutRightPanel"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="36dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/guideline_split"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Track Info Container (vertically centered in the upper space) -->
            <LinearLayout
                android:id="@+id/layoutTrackInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="start"
                app:layout_constraintBottom_toTopOf="@id/layoutProgressContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.45">

                <!-- Track title -->
                <TextView
                    android:id="@+id/tvTrackTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/montserrat_bold"
                    android:gravity="start"
                    android:maxLines="2"
                    android:text="@string/track_title_placeholder"
                    android:textColor="@color/white"
                    android:textSize="52sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:lineSpacingMultiplier="0.88"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="5" />

                <!-- Artist name -->
                <TextView
                    android:id="@+id/tvArtistName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/montserrat_regular"
                    android:gravity="start"
                    android:maxLines="1"
                    android:text="@string/track_artist_placeholder"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="3" />

                <!-- Album name (subtle, below artist) -->
                <TextView
                    android:id="@+id/tvAlbumName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/montserrat_regular"
                    android:gravity="start"
                    android:maxLines="1"
                    android:textColor="#B3FFFFFF"
                    android:textSize="18sp"
                    android:visibility="gone"
                    tools:text="Album Name"
                    tools:visibility="visible"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="3" />

                <!-- Quality badges container -->
                <LinearLayout
                    android:id="@+id/layoutBadges"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal"
                    android:gravity="start"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <!-- Codec Badge -->
                    <TextView
                        android:id="@+id/badgeCodec"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/badge_background"
                        android:textColor="#FF1E1E1E"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="LOSSLESS" />
                </LinearLayout>

            </LinearLayout>

            <!-- Progress container at the bottom -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutProgressContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <!-- Progress bar — thin liquid style -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="4dp"
                    android:max="1000"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_bar_liquid"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Time elapsed (left) -->
                <TextView
                    android:id="@+id/tvTimeElapsed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif"
                    android:text="0:00"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp"
                    android:shadowColor="#80000000"
                    android:shadowRadius="3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/progressBar" />

                <!-- Time remaining (right) -->
                <TextView
                    android:id="@+id/tvTimeRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif"
                    android:text="-0:00"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp"
                    android:shadowColor="#80000000"
                    android:shadowRadius="3"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/progressBar" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
